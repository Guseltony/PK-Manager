// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// enum Roles {
//   admin
//   user
// }

enum AuthProvider {
  EMAIL
  GOOGLE
}

model User {
  id    String @id @default(uuid())
  name  String @default("Anonymous")
  email String @unique

  // 🔐 AUTH
  password String? // made optional (for Google users)
  provider AuthProvider @default(EMAIL)
  googleId String?      @unique

  // ✅ VERIFICATION
  emailVerified Boolean   @default(false)
  verifiedAt    DateTime?

  // 🧠 OPTIONAL PROFILE
  username String?
  avatar   String?

  // 🔗 RELATIONS
  notes    Note[]
  tag      Tag[]
  session  Session[]
  tasks    Task[]
  dreams   Dream[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String
  expiresAt    DateTime
  revoked      Boolean  @default(false)
  createdAt    DateTime @default(now())
  userAgent    String?
  ipAddress    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Note {
  id         String    @id @default(uuid())
  title      String
  content    String
  isArchived Boolean   @default(false)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags       NoteTag[]
  tasks      Task[]
  dreamId    String?
  dream      Dream?    @relation(fields: [dreamId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Tag {
  id        String    @id @default(uuid())
  name      String
  color     String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes     NoteTag[]
  createdAt DateTime  @default(now())

  @@unique([name, userId])
}

model NoteTag {
  id     String @id @default(uuid())
  noteId String
  tagId  String
  note   Note   @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([noteId, tagId])
}

enum TaskStatus {
  todo
  in_progress
  done
}

enum Priority {
  low
  medium
  high
  urgent
}

enum DreamStatus {
  active
  paused
  completed
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String?
  
  status      TaskStatus @default(todo)
  priority    Priority   @default(medium)
  
  dueDate     DateTime?
  estimatedTime Int? // in minutes
  
  tags        String[]
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  noteId      String?
  note        Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  
  dreamId     String?
  dream       Dream?   @relation(fields: [dreamId], references: [id], onDelete: SetNull)
  
  aiScore     Float?
  suggestedAt DateTime?
  
  completedAt DateTime?
  
  subtasks    Subtask[]
  activities  TaskActivity[]
  
  startDate   DateTime? @default(now())
  duration    Int?      @default(1) // in days
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Subtask {
  id      String @id @default(uuid())
  taskId  String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title   String
  status  TaskStatus @default(todo)
}

model Dream {
  id          String   @id @default(uuid())
  title       String
  description String?
  
  status      DreamStatus @default(active)
  category    String?
  priority    Priority    @default(medium)
  
  targetDate  DateTime?
  progress    Float       @default(0)
  healthScore Float       @default(100)
  aiScore     Float?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tasks       Task[]
  notes       Note[]
  milestones  DreamMilestone[]
  insights    DreamInsight[]
  activities  DreamActivity[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
}

model DreamMilestone {
  id          String   @id @default(uuid())
  dreamId     String
  dream       Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  title       String
  description String?
  completed   Boolean  @default(false)
  weight      Float    @default(1)
  targetDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DreamInsight {
  id          String   @id @default(uuid())
  dreamId     String
  dream       Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  message     String
  type        String   // warning, suggestion, progress, prediction
  createdAt   DateTime @default(now())
}

model DreamActivity {
  id          String   @id @default(uuid())
  dreamId     String
  dream       Dream    @relation(fields: [dreamId], references: [id], onDelete: Cascade)
  action      String   // created, updated, progress_updated, milestone_completed
  metadata    Json?
  createdAt   DateTime @default(now())
}

model TaskActivity {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  action    String   // created, updated, completed
  timestamp DateTime @default(now())
}
